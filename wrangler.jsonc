{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "projectcuan",
  "compatibility_date": "2026-06-04",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [".git", "node_modules", ".wrangler", "Source", "Sample", ".agents", ".tasks"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
